/*
  X-Content-Type-Options: nosniff
  X-Robots-Tag: noindex, nofollow, noarchive, nosnippet, noimageindex
  Referrer-Policy: no-referrer
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=()
  Content-Security-Policy: default-src 'self'; base-uri 'none'; object-src 'none'; frame-ancestors 'self'; form-action 'self'; script-src 'self' blob:; style-src 'self' blob:; connect-src 'self' wss:; img-src 'self' data:; media-src 'self'

/formula-assets/*
  Cache-Control: public, max-age=3600

/formula-assets/calculator.js
  Cache-Control: no-cache, must-revalidate
